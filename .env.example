# Database ??Neon serverless PostgreSQL
# Get your pooled connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js secret ??required in all environments
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional: set the canonical app URL used for OAuth redirects
# In Vercel production, use your stable production domain here
AUTH_URL=

# Google OAuth ??create credentials at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
